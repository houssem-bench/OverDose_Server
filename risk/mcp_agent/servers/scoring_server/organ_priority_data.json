  "cumulation_model": {
    "description": "EPA Hazard Index (HI) method adapted with organ-specific priority weights for cumulative risk scoring",
    "references": ["EPA 1986 Chemical Mixtures Guidelines", "EPA 2024 PFAS TOSHI Framework", "PMC6616343 Adversity Specific Hazard Index"],
    "individual_chemical_score": {
      "formula": "organ_weight × inference_score_normalized × evidence_multiplier",
      "evidence_multiplier": {
        "marker/mechanism (direct)": 1.5,
        "inferred only": 1.0,
        "no evidence": 0.0
      },
      "inference_score_normalization": "divide raw inference score by 100 to get 0-1 range"
    },
    "cumulative_score": {
      "formula": "sum(organ_weight[o] × max(score_A[o], score_B[o]) × overlap_synergy[o])",
      "overlap_synergy": {
        "description": "If both chemicals target the same organ, apply synergy multiplier per EPA dose-addition principle",
        "same_organ_both_chemicals": 1.5,
        "same_organ_one_chemical": 1.0
      },
      "risk_thresholds": {
        "low": "0 - 3",
        "moderate": "3 - 6",
        "high": "6 - 10",
        "critical": "> 10"
      }
    }
  },

